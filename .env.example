# --- MongoDB (shared by all concepts; same URI + DB name) ---
# One URI + DB name only (do not write MONGO_URI=MONGO_URL=... on one line).
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# or MONGO_URL=
MONGO_DB_NAME=your_mongo_database
# Legacy aliases also supported: TB_MONGO_DB, PM_MONGO_DB, TB_MONGO_URI, PM_MONGO_URI

# Optional: BSON Date fields instead of calendar strings (YYYY-MM-DD) for yesterday-in-London
# MONGO_USE_UTC_DAY_RANGE=false

# customernacfeedbacks.date — default equality to run_date string (YYYY-MM-DD).
# Use BSON datetime range for London yesterday: set MONGO_CALLS_DATE_KIND=utc_datetime
# MONGO_CALLS_DATE_KIND=iso_date_string

# Optional: force run date (defaults to yesterday in Europe/London)
# OVERRIDE_RUN_DATE=2026-04-16

# Optional: pytest live Mongo advisor list (tests/test_mongo_real_advisors.py -m mongo_live)
# RUN_MONGO_ADVISORS_TEST=1
# INTEGRATION_CONCEPT=people_manager

# --- Supabase: per-concept projects (PM / T&B). Falls back to SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY if unset. ---
PM_SUPABASE_URL=https://your-pm-project.supabase.co
PM_SUPABASE_SERVICE_ROLE_KEY=your_pm_service_role_key
TB_SUPABASE_URL=https://your-tb-project.supabase.co
TB_SUPABASE_SERVICE_ROLE_KEY=your_tb_service_role_key
# Meetings table (per PM/TB project): concepts.py maps meetings.advisor_id → Supabase users.id,
# meetings.date (or override columns / meetings_date_match_mode utc_bounds for timestamptz).
# Optional shared fallback when a per-concept var is missing:
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

VAPI_API_KEY=your_vapi_api_key
VAPI_BASE_URL=https://api.vapi.ai
VAPI_PHONE_NUMBER_ID=
VAPI_PM_PHONE_NUMBER_ID=
VAPI_TB_PHONE_NUMBER_ID=

PHONE_DEFAULT_REGION=US

ADVISOR_OUTREACH_AUDIT_TABLE=

VAPI_MAX_CONCURRENT_PER_CONCEPT=3

# Daily 9:30 London — uses London yesterday for data
ENABLE_SCHEDULER=false
DAILY_CRON=30 9 * * *
SCHEDULER_TZ=Europe/London

# --- Per-concept VAPI assistants only ---
VAPI_PM_ASSISTANT_ID=your_vapi_pm_assistant_id
VAPI_TB_ASSISTANT_ID=your_vapi_tb_assistant_id
